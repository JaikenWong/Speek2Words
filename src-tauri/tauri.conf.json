{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "Speek2Words",
  "version": "0.1.0",
  "identifier": "com.speek2words.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Speek2Words",
        "width": 360,
        "height": 520,
        "resizable": true,
        "closable": true,
        "minimizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/s2w_stt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
